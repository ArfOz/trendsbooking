{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "strictPropertyInitialization": false,
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom", "ES2021.String"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "resolveJsonModule": true,
    "paths": {
      "@auth": ["libs/auth/src"],
      "@auth/*": ["libs/auth/src/*"],
      "@database": ["libs/database/src"],
      "@database/*": ["libs/database/src/*"],
      "@guard": ["libs/guard/src"],
      "@guard/*": ["libs/guard/src/*"],
      "@mail-utils": ["libs/mail-utils/src/index.ts"],
      "@shared": ["libs/shared/src"],
      "@shared/*": ["libs/shared/src/*"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
