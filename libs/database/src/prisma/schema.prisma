datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "./databaseDiagram.pdf"
}

model User {
  /// @HideField({output:true})
  Id         Int       @id @default(autoincrement())
  /// for ex: arif@test.com this have to be unique
  Email      String    @unique
  /// @HideField({output:true})
  Password   String
  /// for ex: arfoz
  Username   String
  /// for ex: Arif, Ozkan, Ahmet
  FirstName  String
  /// for ex: lastname or surname
  LastName   String
  /// for ex: Turkey
  Country    String?
  /// For ex:544672654964  !Important it is string
  Phone      String
  /// for ex: Turkey
  Gender     Gender    @default(NottoSay)
  /// Checkbox Confirmation
  CbFirst    Boolean   @default(false)
  /// for ex: YYYY-MM-DD
  BirthDate  DateTime  @default(now())
  /// @HideField({ input: true, output: true })
  PrivateKey String?
  /// @HideField({ input: true, output: true })
  PublicKey  String?
  /// for ex: YYYY-MM-DD
  CreatedAt  DateTime? @default(now())
  UpdatedAt  DateTime? @updatedAt
  // Email code tables
  UserOTPCode UserOTPCode[]
  // Verified email
  IsEmailVerified Boolean @default(false)
  // Token Table
  UserToken UserToken[]
  /// - It is the UserRole and the default value is *Normal*.
  Role UserRole @default(Normal)
}

model CompanyUser {
  Id              Int           @id @default(autoincrement())
  /// for ex: arif@test.com this have to be unique
  Email           String        @unique
  /// @HideField({output:true})
  Password        String
  /// for ex: Arif, Ozkan, Ahmet
  FirstName       String
  /// for ex: lastname or surname
  LastName        String
  /// for ex : asdasdas
  Username        String
  /// For ex:544672654964  !Important it is string
  Phone           String
  /// for ex: 11111111110
  TCKN            String
  /// Checkbox Confirmation
  CbFirst         Boolean       @default(false)
  /// Vergi numarası
  TaxNo           String
  /// Vergi dairesi
  TaxAdmin        String
  /// Iban Numarası
  IBAN            String
  ///Hizmet verilen Müşteri cinsiyeti
  Sector          Gender[]
  ///Salon Türü
  Salon           String
  /// for ex: Turkey
  Country         String
  /// for ex: Ankara İzmir
  City            String
  /// İlçe 
  District        String
  /// mAHALLE
  Neighborhood    String
  ///Approved
  IsActive        Boolean
  /// for ex: YYYY-MM-DD
  CreatedAt       DateTime      @default(now())
  UpdatedAt       DateTime?     @updatedAt
  /// @HideField({ input: true, output: true })
  PrivateKey      String?
  /// @HideField({ input: true, output: true })
  PublicKey       String?
  UserOTPCode     UserOTPCode[]
  IsEmailVerified Boolean       @default(false)
  UserToken       UserToken[]
  /// - It is the UserRole and the default value is *Provider*.
  Role UserRole @default(Provider)
}

model Department{
    /// @HideField({output:true})
  Id         Int       @id @default(autoincrement())
}

model UserToken {
  /// @HideField({match:'@Input'})
  Id               Int                @id @default(autoincrement())
  /// @HideField({input:true})
  User             User?              @relation(fields: [UserId], references: [Id])
  /// @HideField({input:true})
  UserId           Int?
  /// Companyuser Token
  CompanyUser      CompanyUser?       @relation(fields: [CompanyUserId], references: [Id])
  /// @HideField({input:true})
  CompanyUserId    Int?
  /// @HideField()
  AccessToken      String
  RefreshToken     String
  ExpiresIn        DateTime
  ExpiresInRefresh DateTime
  ExpiredReason    ExpiredReasonType?
  CreatedAt        DateTime           @default(now())
}

model UserOTPCode {
  /// - This field is **required**.
  ///  This will be generated automatically by the database.
  Id            Int          @id @default(autoincrement())
  /// - This field is **required**.
  Code          String
  /// - This field is **required**.
  /// - It is the Int type and the default value is *0*.
  Attempts      Int          @default(0)
  /// - This field is **required**.
  /// - It is the boolean type and the default value is *false*.
  IsDeleted     Boolean      @default(false)
  /// - This field is **required**.
  Type          OTPType
  /// - This field is **required**.
  ExpiredAt     DateTime
  /// - This field is **required**.
  User          User?        @relation(fields: [UserId], references: [Id])
  CompanyUser   CompanyUser? @relation(fields: [CompanyUserId], references: [Id])
  /// - This field is **required**.
  UserId        Int?
  CompanyUserId Int?
  /// - This field is **required**.
  /// - It is the DateTime and the default value is *now*.
  /// - Ex: "2022-06-22T13:49:35.449Z"
  CreatedAt     DateTime     @default(now())
  UpdatedAt     DateTime?    @updatedAt
}

