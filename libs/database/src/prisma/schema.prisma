enum ExpiredReasonType {
  Expired
  SignInFromDifferentLocation
  TokenRefreshed
  Logout
}

enum Gender {
  Male
  Female
  NottoSay
}

enum OTPType {
  VerifyPhone
  VerifyEmail
}

enum UserRole {
  Normal
  Provider
  Admin
}

